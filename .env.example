# ─── Baza de date ─────────────────────────────────────────────────────────────
# Dev (SQLite):
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./prisma/dev.db"
DATABASE_URL_UNPOOLED="file:./prisma/dev.db"

# Prod (Neon PostgreSQL) — copiezi din dashboard Neon → Connection string:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generează cu: openssl rand -base64 32
JWT_SECRET="schimba-cu-un-secret-random-de-minim-32-caractere"

# ─── Admin initial (folosit la seed) ─────────────────────────────────────────
ADMIN_EMAIL="admin@caketopper.ro"
ADMIN_PASSWORD="schimba-parola-dupa-deploy"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Dev: "local" | Prod: "s3"
STORAGE_PROVIDER="local"
UPLOADS_DIR="./uploads"

# Cloudflare R2 (completezi pe Vercel pentru prod):
# STORAGE_PROVIDER="s3"
# S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# S3_BUCKET="caketoppers"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_PUBLIC_URL="https://pub-xxx.r2.dev"   # sau custom domain R2

# ─── App ──────────────────────────────────────────────────────────────────────
# Dev:
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Prod:
# NEXT_PUBLIC_APP_URL="https://caketopperstudio.ro"
