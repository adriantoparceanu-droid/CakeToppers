# ─── Baza de date ─────────────────────────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL="file:./dev.db"
# Prod (PostgreSQL) — decomentează și actualizează:
# DATABASE_URL="postgresql://user:password@host:5432/cake_topper?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generează cu: openssl rand -base64 32
JWT_SECRET="schimba-cu-un-secret-random-de-minim-32-caractere"

# ─── Admin initial (folosit la seed) ─────────────────────────────────────────
ADMIN_EMAIL="admin@caketopper.ro"
ADMIN_PASSWORD="admin1234"

# ─── Storage ──────────────────────────────────────────────────────────────────
# "local" pentru dev, "s3" pentru productie
STORAGE_PROVIDER="local"
UPLOADS_DIR="./uploads"

# ─── Cloudflare R2 / S3 (completezi doar dacă STORAGE_PROVIDER=s3) ───────────
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
