# ─── Baza de date ─────────────────────────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# Prod (Supabase PostgreSQL) — Supabase Dashboard → Settings → Database:
# DATABASE_URL="postgresql://postgres.xxxx:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
# DATABASE_URL_UNPOOLED="postgresql://postgres.xxxx:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generează cu: openssl rand -base64 32
JWT_SECRET="schimba-cu-un-secret-random-de-minim-32-caractere"

# ─── Admin inițial (folosit la seed) ─────────────────────────────────────────
ADMIN_EMAIL="admin@domeniultau.ro"
ADMIN_PASSWORD="schimba-parola-dupa-deploy"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Dev: "local" | Prod: "s3"
STORAGE_PROVIDER="local"
UPLOADS_DIR="./uploads"

# Supabase Storage (completezi pe Vercel pentru prod):
# Supabase Dashboard → Storage → New Bucket "caketoppers" (private)
# Supabase Dashboard → Project Settings → API → S3 Connection Settings
# STORAGE_PROVIDER="s3"
# S3_ENDPOINT="https://xxxx.supabase.co/storage/v1/s3"
# S3_BUCKET="caketoppers"
# S3_REGION="eu-central-1"   (sau altă regiune)
# S3_ACCESS_KEY=""            (din S3 Connection Settings)
# S3_SECRET_KEY=""            (din S3 Connection Settings)
# S3_PUBLIC_URL="https://xxxx.supabase.co/storage/v1/object/public/caketoppers"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Prod:
# NEXT_PUBLIC_APP_URL="https://caketoppers.vercel.app"
